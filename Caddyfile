# ===========================================================
# EverLoad — Caddyfile
#
# CADDY_DOMAIN controls the TLS mode automatically:
#
#   localhost / IP address  →  tls internal (Caddy local CA, self-signed)
#   yourdomain.com          →  Let's Encrypt (automatic, free, auto-renews)
#
# HTTP → HTTPS redirect is handled automatically by Caddy.
# No certificate management needed for production.
# ===========================================================

{
    # Email for Let's Encrypt account and expiry notifications
    email {$CADDY_EMAIL:admin@example.com}

    # Caddy admin API — disable in production if not needed
    # admin off
}

{$CADDY_DOMAIN:localhost} {

    # ── Reverse proxy → Spring Boot ──────────────────────────────────────
    reverse_proxy everload:8080 {
        # Pass real client IP and protocol to Spring Boot.
        # Spring Boot reads these via server.forward-headers-strategy=framework
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host  {host}

        # Disable response buffering — required for:
        #   · Large file downloads (NAS browser, yt-dlp, audio conversion)
        #   · Any streaming or chunked response
        flush_interval -1

        transport http {
            # Time to establish TCP connection to backend
            dial_timeout 10s
            # Time to receive response headers — generous for yt-dlp init
            response_header_timeout 120s
            # Keep-alive pool to avoid TCP handshake on each request
            keepalive 30s
            keepalive_idle_conns 16
        }
    }

    # ── Upload body limit — matches Spring Boot multipart config (500 MB) ─
    request_body {
        max_size 510MB
    }

    # ── Security headers ──────────────────────────────────────────────────
    header {
        # Force HTTPS for 1 year (only sent over HTTPS, ignored on HTTP)
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Prevent MIME-type sniffing
        X-Content-Type-Options "nosniff"
        # Prevent embedding in foreign iframes (clickjacking)
        X-Frame-Options "SAMEORIGIN"
        # Control referrer information
        Referrer-Policy "strict-origin-when-cross-origin"
        # Restrict unnecessary browser features
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        # Remove Caddy/server identity header
        -Server
    }

    # ── Compression ───────────────────────────────────────────────────────
    # Caddy skips compression for already-compressed content (video/audio)
    encode zstd gzip

    # ── Logging — stdout is Docker-native (use docker logs everload-caddy) ─
    log {
        output stdout
        format json
        level INFO
    }
}