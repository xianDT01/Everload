# ============================================================
# EverLoad — Environment variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and NEVER committed to version control.
# ============================================================

# ── Domain ────────────────────────────────────────────────────────────────
# Local dev (self-signed cert, browser will warn):
#   CADDY_DOMAIN=localhost
# Production (Let's Encrypt, ports 80+443 must be open to the internet):
#   CADDY_DOMAIN=everload.yourdomain.com
CADDY_DOMAIN=localhost

# Email for Let's Encrypt certificate notifications
CADDY_EMAIL=admin@yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────
# REQUIRED: change this to a random string of at least 32 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_to_a_long_random_secret_at_least_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# For production with a real domain (same-origin, CORS is not needed for
# the bundled Angular frontend, but set it for external API access):
#   CORS_ALLOWED_ORIGINS=https://everload.yourdomain.com
# For local dev:
#   CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080,http://localhost